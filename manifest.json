{
  "manifest_version": 3,
  "name": "Tabento",
  "version": "3.1.0",
  "description": "Visual workspace for tabs, notes, stacks, and reminders.",
  "permissions": ["tabs", "storage", "contextMenus", "bookmarks", "alarms", "notifications"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tabento",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+E" },
      "description": "Open Tabento popup"
    },
    "save-current-tab": {
      "suggested_key": { "default": "Ctrl+Shift+S" },
      "description": "Save current tab to Inbox"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
