{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "3.1.1",
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "permissions": ["tabs", "storage", "contextMenus", "bookmarks", "alarms", "notifications"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "__MSG_actionTitle__",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+E" },
      "description": "__MSG_commandOpenPopup__"
    },
    "save-current-tab": {
      "suggested_key": { "default": "Ctrl+Shift+S" },
      "description": "__MSG_commandSaveTab__"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
